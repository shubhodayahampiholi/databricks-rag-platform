{
    "datasets": [
      {
        "name": "table_metrics",
        "displayName": "Table Metrics",
        "queryLines": [
          "SELECT\n",
          "  COUNT(*) as total_files,\n",
          "  COUNT(DISTINCT file_type) as unique_file_types,\n",
          "  SUM(file_size) as total_size_bytes,\n",
          "  MAX(ingestion_timestamp) as latest_ingestion,\n",
          "  MIN(ingestion_timestamp) as first_ingestion,\n",
          "  COUNT(\n",
          "    CASE\n",
          "      WHEN processing_status = 'valid' THEN 1\n",
          "    END\n",
          "  ) as valid_files,\n",
          "  COUNT(\n",
          "    CASE\n",
          "      WHEN processing_status != 'valid' THEN 1\n",
          "    END\n",
          "  ) as invalid_files\n",
          "FROM\n",
          "  ${var.team_catalog}.${var.team_schema}.bronze_documents"
        ],
        "catalog": "${var.team_catalog}",
        "schema": "${var.team_schema}"
      },
      {
        "name": "file_type_distribution",
        "displayName": "File Type Distribution",
        "queryLines": [
          "SELECT\n",
          "  file_type,\n",
          "  processing_status,\n",
          "  COUNT(*) as file_count,\n",
          "  SUM(file_size) as total_size_bytes,\n",
          "  AVG(file_size) as avg_size_bytes\n",
          "FROM\n",
          "  ${var.team_catalog}.${var.team_schema}.bronze_documents\n",
          "GROUP BY\n",
          "  file_type,\n",
          "  processing_status\n",
          "ORDER BY\n",
          "  file_count DESC"
        ],
        "catalog": "${var.team_catalog}",
        "schema": "${var.team_schema}"
      },
      {
        "name": "ingestion_timeline",
        "displayName": "Ingestion Timeline",
        "queryLines": [
          "SELECT\n",
          "  DATE_TRUNC('hour', ingestion_timestamp) as ingestion_hour,\n",
          "  COUNT(*) as files_ingested,\n",
          "  SUM(file_size) as total_size_bytes,\n",
          "  COUNT(\n",
          "    CASE\n",
          "      WHEN processing_status = 'valid' THEN 1\n",
          "    END\n",
          "  ) as valid_files,\n",
          "  COUNT(\n",
          "    CASE\n",
          "      WHEN processing_status != 'valid' THEN 1\n",
          "    END\n",
          "  ) as invalid_files\n",
          "FROM\n",
          "  ${var.team_catalog}.${var.team_schema}.bronze_documents\n",
          "WHERE\n",
          "  ingestion_timestamp >= CURRENT_TIMESTAMP - INTERVAL 7 DAYS\n",
          "GROUP BY\n",
          "  DATE_TRUNC('hour', ingestion_timestamp)\n",
          "ORDER BY\n",
          "  ingestion_hour DESC"
        ],
        "catalog": "${var.team_catalog}",
        "schema": "${var.team_schema}"
      },
      {
        "name": "pipeline_events",
        "displayName": "Pipeline Event Log",
        "queryLines": [
          "SELECT\n",
          "  timestamp,\n",
          "  event_type,\n",
          "  level,\n",
          "  message,\n",
          "  details:flow_name as flow_name,\n",
          "  details:flow_type as flow_type\n",
          "FROM\n",
          "  event_log(TABLE(${var.team_catalog}.${var.team_schema}.bronze_documents))\n",
          "WHERE\n",
          "  event_type IN ('flow_progress', 'update_progress')\n",
          "ORDER BY\n",
          "  timestamp DESC\n",
          "LIMIT 100"
        ],
        "catalog": "${var.team_catalog}",
        "schema": "${var.team_schema}"
      },
      {
        "name": "pending_files",
        "displayName": "Pending Files Count",
        "queryLines": [
          "WITH source_files AS (\n",
          "  SELECT\n",
          "    path,\n",
          "    length as size\n",
          "  FROM\n",
          "    read_files(\n",
          "      '/Volumes/${var.team_catalog}/${var.team_schema}/${var.source_volume_name}',\n",
          "      format => 'binaryFile',\n",
          "      recursiveFileLookup => 'true'\n",
          "    )\n",
          ")\n",
          "SELECT\n",
          "  COUNT(*) as pending_files,\n",
          "  COALESCE(SUM(sf.size), 0) as pending_size_bytes\n",
          "FROM\n",
          "  source_files sf\n",
          "LEFT ANTI JOIN\n",
          "  ${var.team_catalog}.${var.team_schema}.bronze_documents bd\n",
          "  ON sf.path = bd.source_path"
        ],
        "catalog": "${var.team_catalog}",
        "schema": "${var.team_schema}"
      }
    ],
